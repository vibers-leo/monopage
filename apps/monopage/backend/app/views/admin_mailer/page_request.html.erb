<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: -apple-system, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .card { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 12px; overflow: hidden; }
    .header { background: #7c3aed; color: #fff; padding: 24px; }
    .header h1 { margin: 0; font-size: 16px; font-weight: 700; }
    .body { padding: 24px; }
    .field { margin-bottom: 16px; }
    .label { font-size: 12px; color: #a3a3a3; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
    .value { font-size: 15px; color: #0a0a0a; font-weight: 500; }
    .btn { display: inline-block; padding: 12px 24px; background: #0a0a0a; color: #fff; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; margin-top: 8px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <h1>추가 페이지 개설 신청</h1>
    </div>
    <div class="body">
      <div class="field">
        <div class="label">희망 주소</div>
        <div class="value">monopage.kr/<%= @username %></div>
      </div>
      <div class="field">
        <div class="label">용도</div>
        <div class="value"><%= @purpose.present? ? @purpose : '미입력' %></div>
      </div>
      <div class="field">
        <div class="label">연락처</div>
        <div class="value"><a href="mailto:<%= @email %>"><%= @email %></a></div>
      </div>
      <a href="https://monopage.kr/admin-console" class="btn">관리자 대시보드에서 확인</a>
    </div>
  </div>
</body>
</html>
