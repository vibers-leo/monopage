<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: -apple-system, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }
    .card { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 12px; overflow: hidden; }
    .header { background: #0a0a0a; color: #fff; padding: 24px; }
    .header h1 { margin: 0; font-size: 16px; font-weight: 700; }
    .header p { margin: 4px 0 0; font-size: 14px; opacity: 0.7; }
    .body { padding: 24px; }
    .field { margin-bottom: 16px; }
    .label { font-size: 12px; color: #a3a3a3; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
    .value { font-size: 15px; color: #0a0a0a; font-weight: 500; }
    .message { background: #f5f5f5; padding: 16px; border-radius: 8px; font-size: 15px; line-height: 1.6; color: #525252; white-space: pre-wrap; }
    .btn { display: inline-block; padding: 12px 24px; background: #0a0a0a; color: #fff; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; margin-top: 16px; }
    .footer { padding: 16px 24px; border-top: 1px solid #e5e5e5; font-size: 12px; color: #a3a3a3; }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <h1>새 문의가 들어왔어요</h1>
      <p>@<%= @profile.username %> 페이지</p>
    </div>
    <div class="body">
      <div class="field">
        <div class="label">이름</div>
        <div class="value"><%= @inquiry.name %></div>
      </div>
      <% if @inquiry.email.present? %>
      <div class="field">
        <div class="label">이메일</div>
        <div class="value"><a href="mailto:<%= @inquiry.email %>"><%= @inquiry.email %></a></div>
      </div>
      <% end %>
      <% if @inquiry.phone.present? %>
      <div class="field">
        <div class="label">연락처</div>
        <div class="value"><a href="tel:<%= @inquiry.phone %>"><%= @inquiry.phone %></a></div>
      </div>
      <% end %>
      <div class="field">
        <div class="label">문의 내용</div>
        <div class="message"><%= @inquiry.message %></div>
      </div>
      <a href="<%= @admin_url %>" class="btn">어드민에서 확인하기</a>
    </div>
    <div class="footer">
      Monopage &mdash; monopage.kr/@<%= @profile.username %>
    </div>
  </div>
</body>
</html>
