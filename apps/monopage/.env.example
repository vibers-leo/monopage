# =============================================
# monopage 환경변수
# =============================================

# === Firebase (Client) ===
# Firebase 웹 API 키
NEXT_PUBLIC_FIREBASE_API_KEY=
# Firebase 인증 도메인
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# Firebase 프로젝트 ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Firebase Storage 버킷
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Firebase 메시징 발신자 ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Firebase 앱 ID
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Supabase ===
# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=
# Supabase 익명(anon) 키
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase 서비스 역할 키 (서버 전용, 마이그레이션용)
SUPABASE_SERVICE_ROLE_KEY=

# === Instagram API ===
# Instagram 앱 클라이언트 ID
INSTAGRAM_CLIENT_ID=
# Instagram 앱 클라이언트 시크릿
INSTAGRAM_CLIENT_SECRET=

# === App ===
# 앱 공개 URL (Instagram 콜백 등에서 사용)
NEXT_PUBLIC_APP_URL=

# AI Recipe Image API (전시 이미지)
IMAGE_API_URL=http://localhost:3300
IMAGE_API_KEY=
