<%= form_with(model: [:admin, bidding], local: true, class: "bidding-form") do |form| %>
  <% if bidding.errors.any? %>
    <div class="error-messages">
      <h3><%= pluralize(bidding.errors.count, "error") %> prohibited this bidding from being saved:</h3>
      <ul>
        <% bidding.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, "사업명" %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= form.label :agency, "공모기관" %>
      <%= form.text_field :agency, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :budget, "예산규모" %>
      <%= form.text_field :budget, placeholder: "예: 5억원", class: "form-control" %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= form.label :application_period, "신청기간" %>
      <%= form.text_field :application_period, placeholder: "2026-03-01 ~ 2026-03-31", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :deadline, "마감일" %>
      <%= form.date_field :deadline, class: "form-control" %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= form.label :status, "상태" %>
      <%= form.select :status, Bidding.status_options, {}, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :progress, "진행률 (%)" %>
      <%= form.number_field :progress, min: 0, max: 100, class: "form-control" %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= form.label :assignee, "담당자" %>
      <%= form.text_field :assignee, placeholder: "레오", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :partner, "협력사" %>
      <%= form.text_field :partner, value: "리멘(Limen)", class: "form-control" %>
    </div>
  </div>

  <div class="form-group">
    <%= form.label :description, "설명" %>
    <%= form.text_area :description, rows: 4, class: "form-control" %>
  </div>

  <div class="divider">
    <span>제안서 작성 지원</span>
  </div>

  <div class="form-group">
    <%= form.label :documents, "첨부 파일 (공고문/RFP/과업지시서)" %>
    <%= form.file_field :documents, multiple: true, class: "form-control-file", accept: ".pdf,.hwp,.doc,.docx" %>
    <small class="form-text">NotebookLM 등 AI 도구로 분석할 문서를 업로드하세요 (PDF, HWP, DOC 등)</small>
    <% if bidding.documents.attached? %>
      <div class="attached-files">
        <% bidding.documents.each do |document| %>
          <div class="file-tag">
            <%= document.filename %> (<%= number_to_human_size(document.byte_size) %>)
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="form-group">
    <%= form.label :analysis_notes, "분석 노트 (NotebookLM 결과)" %>
    <%= form.text_area :analysis_notes, rows: 6, class: "form-control", placeholder: "NotebookLM 등 AI 도구로 공고문을 분석한 결과를 여기에 붙여넣으세요.\n\n예:\n- 사업 핵심 목적: ...\n- 평가 기준: ...\n- 중점 요구사항: ..." %>
  </div>

  <div class="form-group">
    <%= form.label :winning_strategy, "승리 전략" %>
    <%= form.text_area :winning_strategy, rows: 6, class: "form-control", placeholder: "분석 결과를 바탕으로 우리의 강점을 어떻게 어필할지 전략을 작성하세요.\n\n예:\n- 강점 1: 리멘과 협업 → 공간 디자인 전문성\n- 강점 2: ...\n- 차별화 포인트: ..." %>
  </div>

  <div class="form-actions">
    <%= form.submit "저장", class: "btn btn-primary" %>
    <%= link_to "취소", admin_biddings_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<style>
  .bidding-form {
    max-width: 800px;
    background: white;
    padding: 2rem;
    border-radius: 0.5rem;
    border: 1px solid #E5E7EB;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
  }

  .form-control {
    width: 100%;
    padding: 0.625rem;
    border: 1px solid #D1D5DB;
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }

  .form-control:focus {
    outline: none;
    border-color: #1E3A8A;
    box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1);
  }

  textarea.form-control {
    resize: vertical;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .btn {
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background: #1E3A8A;
    color: white;
  }

  .btn-primary:hover {
    background: #3B82F6;
  }

  .btn-secondary {
    background: #E5E7EB;
    color: #374151;
  }

  .btn-secondary:hover {
    background: #D1D5DB;
  }

  .error-messages {
    background: #FEE2E2;
    border: 1px solid #DC2626;
    border-radius: 0.375rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
  }

  .error-messages h3 {
    color: #991B1B;
    font-size: 0.875rem;
    margin: 0 0 0.5rem 0;
  }

  .error-messages ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0;
    color: #991B1B;
    font-size: 0.875rem;
  }

  .divider {
    margin: 2rem 0 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid #E5E7EB;
    position: relative;
  }

  .divider span {
    position: absolute;
    top: -0.625rem;
    left: 0;
    background: white;
    padding: 0 0.5rem;
    color: #1E40AF;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .form-control-file {
    width: 100%;
    padding: 0.625rem;
    border: 2px dashed #D1D5DB;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .form-control-file:hover {
    border-color: #1E40AF;
  }

  .form-text {
    display: block;
    margin-top: 0.5rem;
    color: #6B7280;
    font-size: 0.75rem;
  }

  .attached-files {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .file-tag {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: #DBEAFE;
    color: #1E40AF;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
  }
</style>
